---
import ThemeToggle from "./ThemeToggle.astro";
import { NAV_LINKS } from "../lib/constants";
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="sticky top-0 z-50 border-b border-paper-line/80 bg-paper/85 backdrop-blur-xl dark:border-ink-800/80 dark:bg-ink-950/80">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/" class="font-display text-lg font-extrabold tracking-tight" aria-label="Home">
      rudi<span class="text-signal-500">_</span>firdaus
    </a>

    <ul class="hidden items-center gap-1 sm:flex">
      {NAV_LINKS.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "px-3 py-2 font-mono text-xs uppercase tracking-widest transition-colors",
              isActive(link.href)
                ? "text-signal-500"
                : "text-fog-500 hover:text-ink-900 dark:text-fog-400 dark:hover:text-fog-200",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-1">
      <ThemeToggle />
      <button
        id="menu-toggle"
        type="button"
        class="p-2 text-fog-500 transition-colors hover:text-ink-900 dark:text-fog-400 dark:hover:text-fog-200 sm:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path id="menu-open" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          <path id="menu-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-paper-line/80 px-4 pb-3 pt-2 dark:border-ink-800/80 sm:hidden">
    <ul class="flex flex-col gap-1">
      {NAV_LINKS.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "block px-3 py-2 font-mono text-sm uppercase tracking-widest transition-colors",
              isActive(link.href)
                ? "text-signal-500"
                : "text-fog-500 hover:text-ink-900 dark:text-fog-400 dark:hover:text-fog-200",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const menuOpen = document.getElementById("menu-open")!;
  const menuClose = document.getElementById("menu-close")!;

  menuToggle.addEventListener("click", () => {
    const open = mobileMenu.classList.toggle("hidden");
    menuOpen.classList.toggle("hidden");
    menuClose.classList.toggle("hidden");
    menuToggle.setAttribute("aria-expanded", String(!open));
  });
</script>

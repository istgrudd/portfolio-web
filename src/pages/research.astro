---
import BaseLayout from "../components/BaseLayout.astro";
import { RESEARCH, COAUTHORED_PUBLICATIONS } from "../lib/constants";

const interests = [
  {
    title: "Computer Vision for Traffic Systems",
    body: "Object detection, multi-object tracking, and traffic-parameter estimation from CCTV footage under real-world, low-visibility conditions.",
  },
  {
    title: "NLP for Underrepresented Languages",
    body: "Indonesian NLP with transformer models — emotion classification, NER-based anonymization, and retrieval-augmented systems.",
  },
  {
    title: "Explainable AI & Fairness",
    body: "SHAP-based interpretability, evidence-grounded scoring, and transparent decision pipelines in high-stakes applications.",
  },
  {
    title: "Production ML Systems",
    body: "Bridging research and deployment: containerization, self-hosted APIs, and scalable RAG architectures on commodity infrastructure.",
  },
];
---

<BaseLayout
  title="Research"
  description="First-author IEEE publication at ICSINTESA 2025: Optimizing YOLOv11 for Vehicle Detection in Low-Visibility CCTV Footage. mAP@0.5 0.896, 122 FPS. By Rudi Firdaus."
>
  <script type="application/ld+json" set:html={`{
    "@context": "https://schema.org",
    "@type": "ScholarlyArticle",
    "name": "${RESEARCH.paper.title}",
    "author": { "@type": "Person", "name": "Rudi Firdaus" },
    "datePublished": "${RESEARCH.paper.year}",
    "publisher": { "@type": "Organization", "name": "IEEE" },
    "description": "${RESEARCH.paper.abstract.replace(/"/g, '\\"')}"
  }`} />

  <section class="mx-auto max-w-3xl px-4 pb-20 pt-16 sm:px-6 sm:pt-24">
    <p class="eyebrow">Research</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">Publications &amp; thesis</h1>
    <p class="mt-4 max-w-2xl leading-relaxed text-ink-700 dark:text-fog-300">
      Peer-reviewed work at the intersection of computer vision, deep learning, and intelligent transportation systems.
    </p>

    <!-- Published paper -->
    <div class="mt-12 border border-paper-line bg-paper-raised p-7 dark:border-ink-800 dark:bg-ink-900 sm:p-8">
      <div class="flex flex-wrap items-center gap-3 font-mono text-xs">
        <span class="bg-signal-500 px-2 py-0.5 text-ink-950">IEEE · PUBLISHED</span>
        <span class="text-fog-500 dark:text-fog-400">{RESEARCH.paper.year}</span>
        <span class="text-fog-500 dark:text-fog-400">{RESEARCH.paper.role}</span>
      </div>

      <h2 class="mt-4 text-2xl font-bold leading-snug tracking-tight">{RESEARCH.paper.title}</h2>
      <p class="mt-2 font-mono text-xs text-fog-500 dark:text-fog-400">{RESEARCH.paper.venue}</p>

      <!-- Metrics -->
      <dl class="mt-6 grid grid-cols-2 gap-px border border-paper-line bg-paper-line text-center dark:border-ink-800 dark:bg-ink-800 sm:grid-cols-4">
        <div class="bg-paper-raised py-4 dark:bg-ink-900">
          <dd class="font-display text-xl font-bold text-signal-600 dark:text-signal-400">{RESEARCH.paper.metrics.mAP50}</dd>
          <dt class="mt-1 font-mono text-[0.6rem] uppercase tracking-wide text-fog-500">mAP@0.5</dt>
        </div>
        <div class="bg-paper-raised py-4 dark:bg-ink-900">
          <dd class="font-display text-xl font-bold text-signal-600 dark:text-signal-400">{RESEARCH.paper.metrics.mAP50_95}</dd>
          <dt class="mt-1 font-mono text-[0.6rem] uppercase tracking-wide text-fog-500">mAP@0.5-0.95</dt>
        </div>
        <div class="bg-paper-raised py-4 dark:bg-ink-900">
          <dd class="font-display text-xl font-bold text-signal-600 dark:text-signal-400">{RESEARCH.paper.metrics.fps}</dd>
          <dt class="mt-1 font-mono text-[0.6rem] uppercase tracking-wide text-fog-500">FPS</dt>
        </div>
        <div class="bg-paper-raised py-4 dark:bg-ink-900">
          <dd class="font-display text-xl font-bold text-signal-600 dark:text-signal-400">{RESEARCH.paper.metrics.latency}</dd>
          <dt class="mt-1 font-mono text-[0.6rem] uppercase tracking-wide text-fog-500">latency</dt>
        </div>
      </dl>

      <!-- Abstract -->
      <h3 class="eyebrow mt-7">Abstract</h3>
      <p class="mt-3 text-[0.95rem] leading-relaxed text-ink-700 dark:text-fog-300">{RESEARCH.paper.abstract}</p>

      <p class="mt-5 font-mono text-xs text-fog-500 dark:text-fog-400">
        Co-authors: {RESEARCH.paper.coauthors.join(", ")} · GPU: {RESEARCH.paper.metrics.gpu}
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={RESEARCH.paper.links.ieee} target="_blank" rel="noopener noreferrer" class="btn btn-signal">
          <span aria-hidden="true">▸</span> IEEE Xplore
        </a>
        <a href={RESEARCH.paper.links.doi} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          <span aria-hidden="true">▸</span> DOI
        </a>
      </div>
    </div>

    <!-- Citation -->
    <div class="mt-6 border border-dashed border-paper-line p-5 dark:border-ink-700">
      <h3 class="eyebrow">Cite</h3>
      <p class="mt-3 font-mono text-xs leading-relaxed text-ink-700 dark:text-fog-300">
        R. Firdaus, W. E. Chandra, R. A. P. Pratama, and F. Corputty, &ldquo;Optimizing YOLOv11 for Vehicle Detection in Low-Visibility CCTV Footage,&rdquo; in <em>Proc. 2025 5th Int. Conf. of Science and Information Technology in Smart Administration (ICSINTESA)</em>, IEEE, 2025.
      </p>
    </div>

    <hr class="rule my-14" />

    <!-- Thesis -->
    <div>
      <div class="flex flex-wrap items-center gap-3 font-mono text-xs">
        <span class="border border-signal-500 px-2 py-0.5 text-signal-600 dark:text-signal-400">IN PROGRESS</span>
        <span class="text-fog-500 dark:text-fog-400">Undergraduate thesis</span>
      </div>
      <h2 class="mt-4 text-2xl font-bold tracking-tight">{RESEARCH.thesis.title}</h2>
      <p class="mt-4 text-[0.95rem] leading-relaxed text-ink-700 dark:text-fog-300">{RESEARCH.thesis.approach}</p>

      <div class="mt-6 grid gap-px border border-paper-line bg-paper-line dark:border-ink-800 dark:bg-ink-800 sm:grid-cols-2">
        <div class="bg-paper-raised p-5 dark:bg-ink-900">
          <h3 class="eyebrow">University</h3>
          <p class="mt-3 text-sm text-ink-700 dark:text-fog-300">Telkom University, Bandung — School of Informatics, B.Sc. Data Science</p>
        </div>
        <div class="bg-paper-raised p-5 dark:bg-ink-900">
          <h3 class="eyebrow">Technologies</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {["YOLOv11", "YOLOv26", "ByteTrack", "PyTorch", "OpenCV"].map((t) => (
              <span class="border border-paper-line bg-paper px-2 py-0.5 font-mono text-xs text-ink-700 dark:border-ink-700 dark:bg-ink-850 dark:text-fog-300">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <hr class="rule my-14" />

    <!-- Other publications -->
    <div>
      <p class="eyebrow">Co-authored</p>
      <h2 class="mt-3 text-xl font-bold tracking-tight">Other publications</h2>
      <p class="mt-3 text-sm text-fog-500 dark:text-fog-400">Contributions spanning medical imaging and wireless communications.</p>

      <div class="mt-6 grid gap-6 sm:grid-cols-2">
        {COAUTHORED_PUBLICATIONS.map((pub) => (
          <div class="border border-paper-line bg-paper-raised p-6 dark:border-ink-800 dark:bg-ink-900">
            <div class="flex items-center gap-2 font-mono text-xs text-fog-500 dark:text-fog-400">
              <span class="border border-paper-line px-1.5 dark:border-ink-700">{pub.year}</span>
              <span>{pub.role}</span>
            </div>
            <h3 class="mt-3 font-bold leading-snug">{pub.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-700 dark:text-fog-400">{pub.abstract}</p>
            <p class="mt-3 font-mono text-[0.7rem] text-fog-500 dark:text-fog-400">Co-authors: {pub.coauthors.join(", ")}</p>
          </div>
        ))}
      </div>
    </div>

    <hr class="rule my-14" />

    <!-- Interests -->
    <div>
      <p class="eyebrow">Focus</p>
      <h2 class="mt-3 text-xl font-bold tracking-tight">Research interests</h2>
      <div class="mt-6 grid gap-px border border-paper-line bg-paper-line dark:border-ink-800 dark:bg-ink-800 sm:grid-cols-2">
        {interests.map((it) => (
          <div class="bg-paper-raised p-5 dark:bg-ink-900">
            <h3 class="font-bold">{it.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-fog-500 dark:text-fog-400">{it.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../components/BaseLayout.astro";
import { PERSONAL, RESEARCH, TECH_STACK } from "../lib/constants";
import { getCollection } from "astro:content";

const featuredProjects = await getCollection("projects", ({ data }) => data.featured);
featuredProjects.sort((a, b) => a.data.order - b.data.order);
const pageTitle = "Home";
const pageDescription = "Data Science undergraduate at Telkom University. First-author IEEE publication (ICSINTESA 2025), Vice Head of MBC Laboratory (54 assistants). Computer Vision, Data Engineering, MLOps.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-4 pb-16 pt-20 sm:px-6 sm:pt-28">
    <div class="flex flex-col items-center gap-8 sm:flex-row-reverse sm:justify-between">
      <div class="shrink-0">
        <img
          src="/images/profile.jpg"
          alt="Rudi Firdaus"
          class="h-32 w-32 rounded-full border-2 border-gray-200 object-cover dark:border-gray-700 sm:h-40 sm:w-40"
          width="160"
          height="160"
          loading="eager"
        />
      </div>
      <div class="text-center sm:text-left">
        <p class="text-sm font-medium uppercase tracking-widest text-accent-600 dark:text-accent-400">
          Data Scientist / ML Engineer
        </p>
        <h1 class="mt-2 text-4xl font-extrabold tracking-tight sm:text-5xl">
          {PERSONAL.name}
        </h1>
        <p class="mt-4 max-w-lg text-lg leading-relaxed text-gray-600 dark:text-gray-300">
          {PERSONAL.valueProposition}
        </p>
        <div class="mt-6 flex flex-wrap gap-3 justify-center sm:justify-start">
          <a href="/resume.pdf" download class="inline-flex items-center gap-2 rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-gray-800 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
            Download Resume
          </a>
          <a href="#contact" class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-5 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800">
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Research Highlight -->
  <section class="border-t border-gray-200/60 py-16 dark:border-gray-800/60">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 class="text-center text-2xl font-bold tracking-tight sm:text-3xl">Research</h2>
      <p class="mt-3 text-center text-gray-500 dark:text-gray-400">Peer-reviewed & academic work</p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-gray-200/60 bg-white p-6 transition hover:border-accent-300 dark:border-gray-800/60 dark:bg-gray-900/50 dark:hover:border-accent-700">
          <span class="inline-block rounded-full bg-accent-100 px-3 py-1 text-xs font-semibold text-accent-700 dark:bg-accent-900/40 dark:text-accent-300">IEEE</span>
          <h3 class="mt-3 text-lg font-semibold">{RESEARCH.paper.title}</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{RESEARCH.paper.venue}, {RESEARCH.paper.year} &middot; <strong>{RESEARCH.paper.role}</strong></p>
          <p class="mt-3 text-sm leading-relaxed text-gray-600 dark:text-gray-300">{RESEARCH.paper.abstract}</p>
          <a href={RESEARCH.paper.links.ieee} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent-600 hover:underline dark:text-accent-400">
            View on IEEE Xplore <span>&rarr;</span>
          </a>
        </div>
        <div class="rounded-xl border border-gray-200/60 bg-white p-6 transition hover:border-accent-300 dark:border-gray-800/60 dark:bg-gray-900/50 dark:hover:border-accent-700">
          <span class="inline-block rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700 dark:bg-amber-900/40 dark:text-amber-300">{RESEARCH.thesis.status}</span>
          <h3 class="mt-3 text-lg font-semibold">{RESEARCH.thesis.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-600 dark:text-gray-300">{RESEARCH.thesis.approach}</p>
          <a href="/research" class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent-600 hover:underline dark:text-accent-400">
            Learn more <span>&rarr;</span>
          </a>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a href="/research" class="inline-flex items-center gap-1 text-sm font-medium text-gray-500 transition hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
          View all research <span>&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="border-t border-gray-200/60 py-16 dark:border-gray-800/60">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 class="text-center text-2xl font-bold tracking-tight sm:text-3xl">Featured Projects</h2>
      <p class="mt-3 text-center text-gray-500 dark:text-gray-400">Selected work showcasing research-to-production capabilities</p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <a href={`/projects/${project.id.replace(/\.md$/, "")}`} class="group flex flex-col overflow-hidden rounded-xl border border-gray-200/60 bg-white transition hover:border-accent-300 hover:shadow-sm dark:border-gray-800/60 dark:bg-gray-900/50 dark:hover:border-accent-700">
            {project.data.thumbnail && (
              <div class="h-36 w-full overflow-hidden bg-gray-100 dark:bg-gray-800">
                <img src={project.data.thumbnail} alt={project.data.title} class="h-full w-full object-cover transition group-hover:scale-105" loading="lazy" />
              </div>
            )}
            <div class="flex flex-col flex-1 p-6">
            <div class="flex items-start justify-between gap-2">
              <span class="text-xs font-medium uppercase tracking-wide text-accent-600 dark:text-accent-400">{project.data.category}</span>
              {project.data.status === "in-progress" && (
                <span class="shrink-0 rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700 dark:bg-amber-900/40 dark:text-amber-300">In Progress</span>
              )}
            </div>
            <h3 class="mt-2 text-lg font-semibold group-hover:text-accent-600 dark:group-hover:text-accent-400">{project.data.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600 dark:text-gray-300">{project.data.summary}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {project.data.stack.slice(0, 4).map((tech) => (
                <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-gray-800 dark:text-gray-400">{tech}</span>
              ))}
              {project.data.stack.length > 4 && (
                <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-400 dark:bg-gray-800 dark:text-gray-500">+{project.data.stack.length - 4}</span>
              )}
            </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-6 text-center">
        <a href="/projects" class="inline-flex items-center gap-1 text-sm font-medium text-gray-500 transition hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
          View all projects <span>&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="border-t border-gray-200/60 py-16 dark:border-gray-800/60">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 class="text-center text-2xl font-bold tracking-tight sm:text-3xl">Tech Stack</h2>
      <p class="mt-3 text-center text-gray-500 dark:text-gray-400">Tools I use to ship research to production</p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-gray-200/60 bg-white p-5 dark:border-gray-800/60 dark:bg-gray-900/50">
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-400">Languages</h3>
          <div class="flex flex-wrap gap-1.5">
            {TECH_STACK.languages.map((item) => (
              <span class="rounded-md bg-gray-100 px-2.5 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-300">{item}</span>
            ))}
          </div>
        </div>
        <div class="rounded-xl border border-gray-200/60 bg-white p-5 dark:border-gray-800/60 dark:bg-gray-900/50">
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-400">ML / DL</h3>
          <div class="flex flex-wrap gap-1.5">
            {TECH_STACK.mlDl.map((item) => (
              <span class="rounded-md bg-gray-100 px-2.5 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-300">{item}</span>
            ))}
          </div>
        </div>
        <div class="rounded-xl border border-gray-200/60 bg-white p-5 dark:border-gray-800/60 dark:bg-gray-900/50">
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-400">MLOps & Infra</h3>
          <div class="flex flex-wrap gap-1.5">
            {TECH_STACK.mlOpsInfra.map((item) => (
              <span class="rounded-md bg-gray-100 px-2.5 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-300">{item}</span>
            ))}
          </div>
        </div>
        <div class="rounded-xl border border-gray-200/60 bg-white p-5 dark:border-gray-800/60 dark:bg-gray-900/50">
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-400">Full-stack</h3>
          <div class="flex flex-wrap gap-1.5">
            {TECH_STACK.fullstack.map((item) => (
              <span class="rounded-md bg-gray-100 px-2.5 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-300">{item}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="border-t border-gray-200/60 py-16 dark:border-gray-800/60">
    <div class="mx-auto max-w-5xl px-4 text-center sm:px-6">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Get in Touch</h2>
      <p class="mt-3 text-gray-500 dark:text-gray-400">Open to opportunities — let&rsquo;s talk.</p>

      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={PERSONAL.links.email} class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-5 py-3 text-sm font-medium text-gray-700 transition hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          Email
        </a>
        <a href={PERSONAL.links.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-5 py-3 text-sm font-medium text-gray-700 transition hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href={PERSONAL.links.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-5 py-3 text-sm font-medium text-gray-700 transition hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
          GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../components/BaseLayout.astro";
import DetectFrame from "../components/DetectFrame.astro";
import { PERSONAL, RESEARCH, TECH_STACK } from "../lib/constants";
import { getCollection } from "astro:content";

const featuredProjects = await getCollection("projects", ({ data }) => data.featured);
featuredProjects.sort((a, b) => a.data.order - b.data.order);

const stackGroups = [
  { label: "Languages", items: TECH_STACK.languages },
  { label: "ML / DL", items: TECH_STACK.mlDl },
  { label: "MLOps & Infra", items: TECH_STACK.mlOpsInfra },
  { label: "Full-stack", items: TECH_STACK.fullstack },
];

const pageTitle = "Home";
const pageDescription =
  "Rudi Firdaus — ML engineer and researcher. First-author IEEE publication (ICSINTESA 2025), Vice Head of MBC Laboratory, builder of production AI systems. Computer Vision, NLP, data infrastructure.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative overflow-hidden">
    <div class="sensor-grid pointer-events-none absolute inset-0"></div>
    <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 pb-20 pt-16 sm:px-6 sm:pt-24 lg:grid-cols-[1.4fr_1fr]">
      <!-- Detected subject: identity block -->
      <DetectFrame label="rudi_firdaus" meta="conf:0.99" acquire={true} class="order-2 p-6 sm:p-8 lg:order-1">
        <p class="eyebrow">{PERSONAL.role}</p>
        <h1 class="mt-4 font-display text-5xl font-extrabold leading-[0.95] tracking-tight [font-stretch:112%] sm:text-6xl lg:text-7xl">
          RUDI<br />FIRDAUS
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-ink-700 dark:text-fog-300">
          {PERSONAL.valueProposition}
        </p>

        <!-- Telemetry readout -->
        <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-fog-500 dark:text-fog-400">
          <span>IEEE first-author</span>
          <span class="text-signal-500">·</span>
          <span>mAP@0.5 <span class="text-ink-900 dark:text-fog-200">0.896</span></span>
          <span class="text-signal-500">·</span>
          <span><span class="text-ink-900 dark:text-fog-200">122</span> FPS</span>
          <span class="text-signal-500">·</span>
          <span>ScreenAI <span class="text-ink-900 dark:text-fog-200">in production</span></span>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/resume.pdf" download class="btn btn-signal">
            <span aria-hidden="true">▸</span> Download CV
          </a>
          <a href="#contact" class="btn btn-ghost">
            <span aria-hidden="true">▸</span> Get in touch
          </a>
        </div>
      </DetectFrame>

      <!-- Portrait -->
      <div class="order-1 flex justify-center lg:order-2 lg:justify-end">
        <div class="relative">
          <img
            src="/images/profile.jpg"
            alt="Rudi Firdaus"
            class="h-44 w-44 object-cover grayscale-[0.15] ring-1 ring-paper-line transition-all duration-500 hover:grayscale-0 hover:ring-signal-500/60 dark:ring-ink-700 sm:h-56 sm:w-56 lg:h-64 lg:w-64"
            width="256"
            height="256"
            loading="eager"
          />
          <span class="absolute -bottom-3 left-3 bg-ink-950 px-2 py-1 font-mono text-[0.65rem] text-signal-500 ring-1 ring-ink-700">
            cls:human · {PERSONAL.location}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ RESEARCH ═══════════════ -->
  <section class="border-t border-paper-line/70 dark:border-ink-800/70">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="eyebrow">Research</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight sm:text-3xl">Peer-reviewed &amp; in progress</h2>
        </div>
        <a href="/research" class="hidden shrink-0 font-mono text-xs uppercase tracking-widest text-signal-600 hover:underline dark:text-signal-400 sm:inline">
          All research →
        </a>
      </div>

      <div class="reveal mt-10 grid gap-px overflow-hidden border border-paper-line bg-paper-line dark:border-ink-800 dark:bg-ink-800 lg:grid-cols-5">
        <!-- Paper -->
        <div class="bg-paper-raised p-7 dark:bg-ink-900 lg:col-span-3">
          <div class="flex items-center gap-3 font-mono text-xs">
            <span class="bg-signal-500 px-2 py-0.5 text-ink-950">IEEE · PUBLISHED</span>
            <span class="text-fog-500 dark:text-fog-400">{RESEARCH.paper.year}</span>
            <span class="text-fog-500 dark:text-fog-400">{RESEARCH.paper.role}</span>
          </div>
          <h3 class="mt-4 text-xl font-bold leading-snug">{RESEARCH.paper.title}</h3>
          <p class="mt-2 font-mono text-xs text-fog-500 dark:text-fog-400">{RESEARCH.paper.venue}</p>

          <dl class="mt-6 grid grid-cols-4 gap-px border border-paper-line bg-paper-line text-center dark:border-ink-800 dark:bg-ink-800">
            <div class="bg-paper-raised py-3 dark:bg-ink-900">
              <dd class="font-display text-lg font-bold text-signal-600 dark:text-signal-400">{RESEARCH.paper.metrics.mAP50}</dd>
              <dt class="mt-0.5 font-mono text-[0.6rem] uppercase tracking-wide text-fog-500">mAP@.5</dt>
            </div>
            <div class="bg-paper-raised py-3 dark:bg-ink-900">
              <dd class="font-display text-lg font-bold text-signal-600 dark:text-signal-400">{RESEARCH.paper.metrics.mAP50_95}</dd>
              <dt class="mt-0.5 font-mono text-[0.6rem] uppercase tracking-wide text-fog-500">mAP@.5-.95</dt>
            </div>
            <div class="bg-paper-raised py-3 dark:bg-ink-900">
              <dd class="font-display text-lg font-bold text-signal-600 dark:text-signal-400">{RESEARCH.paper.metrics.fps}</dd>
              <dt class="mt-0.5 font-mono text-[0.6rem] uppercase tracking-wide text-fog-500">FPS</dt>
            </div>
            <div class="bg-paper-raised py-3 dark:bg-ink-900">
              <dd class="font-display text-lg font-bold text-signal-600 dark:text-signal-400">{RESEARCH.paper.metrics.latency}</dd>
              <dt class="mt-0.5 font-mono text-[0.6rem] uppercase tracking-wide text-fog-500">latency</dt>
            </div>
          </dl>

          <a href={RESEARCH.paper.links.ieee} target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex items-center gap-1 font-mono text-xs uppercase tracking-widest text-signal-600 hover:underline dark:text-signal-400">
            View on IEEE Xplore →
          </a>
        </div>

        <!-- Thesis -->
        <div class="bg-paper-raised p-7 dark:bg-ink-900 lg:col-span-2">
          <div class="flex items-center gap-3 font-mono text-xs">
            <span class="border border-signal-500 px-2 py-0.5 text-signal-600 dark:text-signal-400">IN PROGRESS</span>
            <span class="text-fog-500 dark:text-fog-400">Thesis</span>
          </div>
          <h3 class="mt-4 text-xl font-bold leading-snug">{RESEARCH.thesis.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-700 dark:text-fog-300">{RESEARCH.thesis.approach}</p>
          <a href="/research" class="mt-6 inline-flex items-center gap-1 font-mono text-xs uppercase tracking-widest text-signal-600 hover:underline dark:text-signal-400">
            Read more →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ FEATURED PROJECTS ═══════════════ -->
  <section class="border-t border-paper-line/70 dark:border-ink-800/70">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight sm:text-3xl">Research, shipped to production</h2>
        </div>
        <a href="/projects" class="hidden shrink-0 font-mono text-xs uppercase tracking-widest text-signal-600 hover:underline dark:text-signal-400 sm:inline">
          All projects →
        </a>
      </div>

      <div class="reveal mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <a href={`/projects/${project.id.replace(/\.md$/, "")}`} class="card-edge group flex flex-col border border-paper-line bg-paper-raised dark:border-ink-800 dark:bg-ink-900">
            {project.data.thumbnail ? (
              <div class="aspect-[16/10] w-full overflow-hidden border-b border-paper-line bg-paper dark:border-ink-800 dark:bg-ink-850">
                <img src={project.data.thumbnail} alt={project.data.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              </div>
            ) : (
              <div class="flex aspect-[16/10] w-full items-center justify-center border-b border-paper-line bg-paper font-mono text-xs text-fog-400 dark:border-ink-800 dark:bg-ink-850">
                <span>cls:{project.data.category.toLowerCase().replace(/[\s/]+/g, "_")}</span>
              </div>
            )}
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center justify-between gap-2 font-mono text-xs">
                <span class="text-signal-600 dark:text-signal-400">{project.data.category}</span>
                {project.data.status === "in-progress" && (
                  <span class="border border-signal-500 px-1.5 text-signal-600 dark:text-signal-400">WIP</span>
                )}
              </div>
              <h3 class="mt-2 text-lg font-bold leading-snug group-hover:text-signal-600 dark:group-hover:text-signal-400">{project.data.title}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-700 dark:text-fog-400">{project.data.summary}</p>
              <div class="mt-4 flex flex-wrap gap-1.5">
                {project.data.stack.slice(0, 4).map((tech) => (
                  <span class="bg-paper px-2 py-0.5 font-mono text-[0.7rem] text-fog-500 dark:bg-ink-850 dark:text-fog-400">{tech}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>

      <a href="/projects" class="mt-8 inline-flex font-mono text-xs uppercase tracking-widest text-signal-600 hover:underline dark:text-signal-400 sm:hidden">
        All projects →
      </a>
    </div>
  </section>

  <!-- ═══════════════ STACK ═══════════════ -->
  <section class="border-t border-paper-line/70 dark:border-ink-800/70">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <p class="eyebrow">Stack</p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight sm:text-3xl">Tools I actually use</h2>

      <div class="reveal mt-10 grid gap-px border border-paper-line bg-paper-line dark:border-ink-800 dark:bg-ink-800 sm:grid-cols-2 lg:grid-cols-4">
        {stackGroups.map((group) => (
          <div class="bg-paper-raised p-6 dark:bg-ink-900">
            <h3 class="font-mono text-xs uppercase tracking-widest text-fog-500 dark:text-fog-400">{group.label}</h3>
            <ul class="mt-4 space-y-2">
              {group.items.map((item) => (
                <li class="flex items-center gap-2 text-sm text-ink-700 dark:text-fog-300">
                  <span class="h-1 w-1 shrink-0 bg-signal-500"></span>{item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ CONTACT ═══════════════ -->
  <section id="contact" class="border-t border-paper-line/70 dark:border-ink-800/70">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <DetectFrame label="status" meta="open_to_work" class="p-8 sm:p-12">
        <p class="eyebrow">Contact</p>
        <h2 class="mt-4 max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">
          Building something that needs research-grade ML and a path to production?
        </h2>
        <p class="mt-4 max-w-xl text-base leading-relaxed text-ink-700 dark:text-fog-300">
          I'm open to ML engineering and applied-research roles — including relocation. Let's talk.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={PERSONAL.links.email} class="btn btn-signal"><span aria-hidden="true">▸</span> Email</a>
          <a href={PERSONAL.links.linkedin} target="_blank" rel="noopener noreferrer" class="btn btn-ghost"><span aria-hidden="true">▸</span> LinkedIn</a>
          <a href={PERSONAL.links.github} target="_blank" rel="noopener noreferrer" class="btn btn-ghost"><span aria-hidden="true">▸</span> GitHub</a>
        </div>
      </DetectFrame>
    </div>
  </section>
</BaseLayout>

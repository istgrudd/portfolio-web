---
import BaseLayout from "../components/BaseLayout.astro";
import { PERSONAL, TECH_STACK, LEADERSHIP } from "../lib/constants";
---

<BaseLayout
  title="About"
  description="Rudi Firdaus — Data Science student at Telkom University, first-author IEEE publication at ICSINTESA 2025, Vice Head of MBC Laboratory (54 assistants), and builder of production AI systems."
>
  <section class="mx-auto max-w-3xl px-4 pb-16 pt-16 sm:px-6 sm:pt-24">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">About</h1>

    <!-- Bio -->
    <div class="mt-10 max-w-2xl">
      <h2 class="text-xl font-bold">Bio</h2>
      <div class="mt-4 space-y-4 leading-relaxed text-gray-600 dark:text-gray-300">
        <p>
          I&rsquo;m Rudi Firdaus, a final-year Data Science student at Telkom University, Bandung, specializing in computer vision and data engineering. My work sits at the intersection of research and production—I build models that work in adverse conditions and systems that real teams depend on.
        </p>
        <p>
          I published my first IEEE paper as a first author at ICSINTESA 2025—optimizing YOLOv11 for vehicle detection in low-visibility CCTV footage, achieving mAP@0.5 of 0.896 with 122 FPS real-time inference. That research now forms the foundation for my ongoing thesis on traffic flow estimation.
        </p>
        <p>
          On the engineering side, I built ScreenAI (AI recruitment screening with NER + RAG + XAI) as a capstone project with a team of 4, and LabLink—a full-stack internal information system for MBC Laboratory, built solo and adopted across all 4 divisions. I also completed a Data Engineer internship at PT Metrocom, working on pipeline integration and query tuning.
        </p>
      </div>
    </div>

    <!-- Leadership -->
    <div class="mt-12">
      <h2 class="text-xl font-bold">Leadership</h2>
      <div class="mt-4 rounded-xl border border-gray-200/60 bg-gray-50/50 p-6 dark:border-gray-800/60 dark:bg-gray-900/30">
        <div class="flex flex-wrap items-center justify-between gap-2">
          <h3 class="font-semibold">{LEADERSHIP.role}</h3>
          <span class="text-sm text-gray-400">{LEADERSHIP.period}</span>
        </div>
        <ul class="mt-4 space-y-2">
          {LEADERSHIP.highlights.map((item) => (
            <li class="flex items-start gap-2 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Skills -->
    <div class="mt-12">
      <h2 class="text-xl font-bold">Skills</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-gray-200/60 p-5 dark:border-gray-800/60">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-400">Languages</h3>
          <div class="mt-3 flex flex-wrap gap-1.5">
            {TECH_STACK.languages.map((item) => (
              <span class="rounded-md bg-gray-100 px-2.5 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-300">{item}</span>
            ))}
          </div>
        </div>
        <div class="rounded-xl border border-gray-200/60 p-5 dark:border-gray-800/60">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-400">ML / DL</h3>
          <div class="mt-3 flex flex-wrap gap-1.5">
            {TECH_STACK.mlDl.map((item) => (
              <span class="rounded-md bg-gray-100 px-2.5 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-300">{item}</span>
            ))}
          </div>
        </div>
        <div class="rounded-xl border border-gray-200/60 p-5 dark:border-gray-800/60">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-400">MLOps & Infra</h3>
          <div class="mt-3 flex flex-wrap gap-1.5">
            {TECH_STACK.mlOpsInfra.map((item) => (
              <span class="rounded-md bg-gray-100 px-2.5 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-300">{item}</span>
            ))}
          </div>
        </div>
        <div class="rounded-xl border border-gray-200/60 p-5 dark:border-gray-800/60">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-400">Full-stack</h3>
          <div class="mt-3 flex flex-wrap gap-1.5">
            {TECH_STACK.fullstack.map((item) => (
              <span class="rounded-md bg-gray-100 px-2.5 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-300">{item}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="mt-12">
      <h2 class="text-xl font-bold">Journey</h2>
      <div class="mt-6 space-y-0">
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
            <div class="h-full w-px bg-gray-200 dark:bg-gray-800"></div>
          </div>
          <div class="pb-8">
            <span class="text-sm text-gray-400">Jun 2026</span>
            <h3 class="font-semibold">Top 10 Finalist — Dolanan Data Nexus</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              National data mining competition. Swin Transformer + FPN for semantic segmentation of post-flood UAV imagery.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
            <div class="h-full w-px bg-gray-200 dark:bg-gray-800"></div>
          </div>
          <div class="pb-8">
            <span class="text-sm text-gray-400">May 2026</span>
            <h3 class="font-semibold">Vice Head — MBC Laboratory</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              Oversees 54 assistants across 4 divisions. Manages research infrastructure, internal tooling, and lab-wide coordination.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
            <div class="h-full w-px bg-gray-200 dark:bg-gray-800"></div>
          </div>
          <div class="pb-8">
            <span class="text-sm text-gray-400">2026</span>
            <h3 class="font-semibold">ScreenAI — Capstone + Thesis</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              AI recruitment screening: blind screening (NER) + competency match (RAG) + XAI. Team of 4, 440 CVs. Production fork deployed at MBC Lab. Also ongoing thesis on traffic flow estimation.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
            <div class="h-full w-px bg-gray-200 dark:bg-gray-800"></div>
          </div>
          <div class="pb-8">
            <span class="text-sm text-gray-400">Nov 2025</span>
            <h3 class="font-semibold">First Author — ICSINTESA 2025 (IEEE)</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              Optimizing YOLOv11 for vehicle detection in low-visibility CCTV. mAP@0.5: 0.896, 122 FPS. Peer-reviewed IEEE publication.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
            <div class="h-full w-px bg-gray-200 dark:bg-gray-800"></div>
          </div>
          <div class="pb-8">
            <span class="text-sm text-gray-400">Jul 2025</span>
            <h3 class="font-semibold">Data Engineer Intern — PT Metrocom</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              Pipeline integration and query tuning for data engineering workflows.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
            <div class="h-full w-px bg-gray-200 dark:bg-gray-800"></div>
          </div>
          <div class="pb-8">
            <span class="text-sm text-gray-400">Jun 2025</span>
            <h3 class="font-semibold">Head of Big Data Division</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              Led 16 researchers to 6 publications with 100% project success rate. Designed Agile sprint framework for the division.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
            <div class="h-full w-px bg-gray-200 dark:bg-gray-800"></div>
          </div>
          <div class="pb-8">
            <span class="text-sm text-gray-400">Jan 2025</span>
            <h3 class="font-semibold">Best Presentation — ADIKARA</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              Awarded Best Presentation at the ADIKARA Data Mining Competition.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
            <div class="h-full w-px bg-gray-200 dark:bg-gray-800"></div>
          </div>
          <div class="pb-8">
            <span class="text-sm text-gray-400">Oct 2024</span>
            <h3 class="font-semibold">Research Assistant — MBC Laboratory</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              Started computer vision research at MBC Lab, focusing on object detection for traffic systems.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
          </div>
          <div class="pb-4">
            <span class="text-sm text-gray-400">Sep 2023</span>
            <h3 class="font-semibold">B.Sc. Data Science — Telkom University</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              GPA 3.46 / 4.0. School of Informatics, Bandung, Indonesia.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../../components/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data, body } = post;

function readingTime(text: string): number {
  const words = text.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const langLabels: Record<string, string> = { en: "EN", id: "ID" };
---

<BaseLayout title={data.title} description={data.summary} ogType="article">
  <article class="mx-auto max-w-3xl px-4 pb-20 pt-12 sm:px-6 sm:pt-16">
    <a href="/blog" class="inline-flex items-center gap-1 font-mono text-xs uppercase tracking-widest text-fog-500 transition-colors hover:text-signal-600 dark:text-fog-400 dark:hover:text-signal-400">
      ← Blog
    </a>

    <div class="mt-8 flex flex-wrap items-center gap-3 font-mono text-xs text-fog-500 dark:text-fog-400">
      <time datetime={data.date.toISOString()}>
        {data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      </time>
      <span class="border border-paper-line px-1.5 dark:border-ink-700">{langLabels[data.lang] ?? data.lang.toUpperCase()}</span>
      <span>{readingTime(body ?? "")} min read</span>
    </div>

    <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">{data.title}</h1>
    <p class="mt-4 text-lg leading-relaxed text-ink-700 dark:text-fog-300">{data.summary}</p>

    {data.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2 font-mono text-xs text-fog-500 dark:text-fog-400">
        {data.tags.map((tag) => <span>#{tag}</span>)}
      </div>
    )}

    <hr class="rule mt-8" />

    <div class="prose prose-gray mt-10 max-w-none dark:prose-invert
      prose-headings:font-display prose-headings:tracking-tight
      prose-h2:mt-10 prose-h2:text-2xl
      prose-h3:mt-8 prose-h3:text-xl
      prose-p:leading-relaxed prose-p:text-ink-700 dark:prose-p:text-fog-300
      prose-a:text-signal-600 prose-a:no-underline hover:prose-a:underline dark:prose-a:text-signal-400
      prose-strong:text-ink-900 dark:prose-strong:text-fog-200
      prose-code:rounded-none prose-code:bg-paper prose-code:px-1.5 prose-code:py-0.5 prose-code:font-mono prose-code:text-sm prose-code:font-normal prose-code:before:content-[''] prose-code:after:content-[''] dark:prose-code:bg-ink-850
      prose-pre:rounded-none prose-pre:border prose-pre:border-paper-line prose-pre:bg-ink-900 prose-pre:text-fog-200 dark:prose-pre:border-ink-800
      prose-img:rounded-none
      prose-blockquote:border-l-2 prose-blockquote:border-l-signal-500 prose-blockquote:not-italic prose-blockquote:text-fog-500
      prose-table:text-sm prose-th:px-4 prose-th:py-2 prose-td:px-4 prose-td:py-2
    ">
      <Content />
    </div>
  </article>
</BaseLayout>

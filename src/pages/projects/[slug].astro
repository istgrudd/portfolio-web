---
import BaseLayout from "../../components/BaseLayout.astro";
import DetectFrame from "../../components/DetectFrame.astro";
import RichText from "../../components/RichText.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.md$/, "") },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { data, body } = project;
const pageTitle = `${data.title} — Projects`;

const sections = [
  { label: "Problem", text: data.problem },
  { label: "Approach", text: data.approach },
  { label: "Results", text: data.results },
  { label: "Architecture", text: data.architecture },
  { label: "Technical decisions", text: data.decisions },
  { label: "Lessons", text: data.lessons },
].filter((s): s is { label: string; text: string } => Boolean(s.text));

const hasExtraBody = (body ?? "").trim().length > 0;
---

<BaseLayout title={pageTitle} description={data.summary}>
  <article class="mx-auto max-w-3xl px-4 pb-20 pt-12 sm:px-6 sm:pt-16">
    <a href="/projects" class="inline-flex items-center gap-1 font-mono text-xs uppercase tracking-widest text-fog-500 transition-colors hover:text-signal-600 dark:text-fog-400 dark:hover:text-signal-400">
      ← Projects
    </a>

    <!-- Header -->
    <div class="mt-8 flex flex-wrap items-center gap-3 font-mono text-xs">
      <span class="bg-signal-500 px-2 py-0.5 text-ink-950">cls:{data.category.toLowerCase().replace(/[\s/]+/g, "_")}</span>
      {data.timeframe && <span class="text-fog-500 dark:text-fog-400">{data.timeframe}</span>}
      {data.status === "in-progress" && (
        <span class="border border-signal-500 px-2 py-0.5 text-signal-600 dark:text-signal-400">IN PROGRESS</span>
      )}
    </div>
    <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">{data.title}</h1>
    <p class="mt-4 text-lg leading-relaxed text-ink-700 dark:text-fog-300">{data.summary}</p>

    <!-- Quick links -->
    <div class="mt-6 flex flex-wrap gap-3">
      {data.links.github && data.links.github !== "#" && (
        <a href={data.links.github} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
          Source
        </a>
      )}
      {data.links.demo && data.links.demo !== "#" && (
        <a href={data.links.demo} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          Live demo
        </a>
      )}
      {data.links.paper && (
        <a href={data.links.paper} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          Paper
        </a>
      )}
    </div>

    <!-- Thumbnail -->
    {data.thumbnail && (
      <DetectFrame label={data.title.toLowerCase().replace(/\s+/g, "_")} meta="conf:0.97" class="mt-10">
        <div class="overflow-hidden bg-paper dark:bg-ink-850">
          <img src={data.thumbnail} alt={data.title} class="w-full object-cover" loading="eager" />
        </div>
      </DetectFrame>
    )}

    <!-- Metrics -->
    {data.metrics.length > 0 && (
      <dl class:list={["mt-10 grid gap-px border border-paper-line bg-paper-line text-center dark:border-ink-800 dark:bg-ink-800", data.metrics.length === 3 ? "grid-cols-3" : "grid-cols-2 sm:grid-cols-4"]}>
        {data.metrics.map((m) => (
          <div class="bg-paper-raised px-3 py-5 dark:bg-ink-900">
            <dd class="font-display text-2xl font-bold text-signal-600 dark:text-signal-400">{m.value}</dd>
            <dt class="mt-1 font-mono text-[0.65rem] uppercase tracking-wide text-fog-500 dark:text-fog-400">{m.label}</dt>
          </div>
        ))}
      </dl>
    )}

    <!-- Role -->
    <div class="mt-10 border-t border-paper-line/70 pt-8 dark:border-ink-800/70">
      <h2 class="eyebrow">My role</h2>
      <p class="mt-3 text-[0.95rem] leading-relaxed text-ink-700 dark:text-fog-300">{data.role}</p>
    </div>

    <!-- Narrative sections -->
    {sections.map((section) => (
      <div class="mt-10 border-t border-paper-line/70 pt-8 dark:border-ink-800/70">
        <h2 class="eyebrow">{section.label}</h2>
        <RichText text={section.text} class="mt-4" />
      </div>
    ))}

    <!-- Stack -->
    <div class="mt-10 border-t border-paper-line/70 pt-8 dark:border-ink-800/70">
      <h2 class="eyebrow">Stack</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {data.stack.map((tech) => (
          <span class="border border-paper-line bg-paper px-2.5 py-1 font-mono text-xs text-ink-700 dark:border-ink-700 dark:bg-ink-850 dark:text-fog-300">{tech}</span>
        ))}
      </div>
      {data.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2 font-mono text-xs text-fog-500 dark:text-fog-400">
          {data.tags.map((tag) => <span>#{tag.toLowerCase().replace(/\s+/g, "-")}</span>)}
        </div>
      )}
    </div>

    <!-- Optional extended markdown body -->
    {hasExtraBody && (
      <div class="prose prose-sm mt-10 max-w-none border-t border-paper-line/70 pt-8 dark:prose-invert dark:border-ink-800/70
        prose-headings:font-display prose-pre:bg-ink-900 prose-pre:text-fog-200
        prose-a:text-signal-600 dark:prose-a:text-signal-400">
        <Content />
      </div>
    )}
  </article>
</BaseLayout>
